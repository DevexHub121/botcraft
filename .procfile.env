# BotCraft Procfile Environment Variables Guide
# ============================================================
# Copy these variables to your deployment platform
# (Heroku Config Vars, Docker env, etc.)
# ============================================================

# Core Application
SECRET_KEY=your-jwt-secret-key-here-change-in-production
PORT=5000

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Email Configuration (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-email-app-password-here

# Payment Gateway - Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=rzp_your_secret_key

# Authentication - Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://botcraft.devexhub.com/auth/google/callback

# Admin Configuration
ADMIN_EMAIL=admin@yourdomain.com

# Database (Optional - for PostgreSQL/MySQL)
# DATABASE_URL=postgresql://user:password@localhost/botcraft
# For SQLite (default): Leave empty or set to db/chatbot.db

# Database Path
DATABASE_PATH=db/chatbot.db

# ============================================================
# Notes for Heroku Deployment:
# ============================================================
# 1. Set these config variables using: heroku config:set VAR_NAME=value
# 2. Or use: heroku config:set --from-file .env
# 3. View set variables: heroku config
# 4. Don't commit this file if it contains real secrets - use .gitignore
# ============================================================
